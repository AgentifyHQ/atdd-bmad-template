# ──────────────────────────────────────────────
# Target Application URLs
# Used by: acceptance, api tests
# ──────────────────────────────────────────────
APP_URL=http://localhost:3000
API_URL=http://localhost:3000

# ──────────────────────────────────────────────
# Multi-Service Integration (override per service)
# Used by: integration tests
# ──────────────────────────────────────────────
USER_SERVICE_URL=http://localhost:3001
ORDER_SERVICE_URL=http://localhost:3002
INVENTORY_SERVICE_URL=http://localhost:3003

# ──────────────────────────────────────────────
# Authentication (for tests requiring auth)
# Used by: acceptance, api tests
# ──────────────────────────────────────────────
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=test-password-change-me
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=admin-password-change-me

# ──────────────────────────────────────────────
# LLM API Keys
# Used by: prompt-eval (TS + Python)
#
# .env is loaded by ALL runners:
#   - playwright.config.ts via dotenv/config
#   - conftest.py via python-dotenv
#   - promptfoo CLI auto-loads .env
#
# Required for @semantic, @llm-judge, @rag, @faithfulness tests.
# Not needed for @deterministic tests.
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────
# DeepEval (optional)
# Used by: prompt-eval Python runner
# Only needed if using Confident AI cloud dashboard.
# ──────────────────────────────────────────────
# DEEPEVAL_API_KEY=
# DEEPEVAL_RESULTS_FOLDER=tests/prompt-eval/python/results

# ──────────────────────────────────────────────
# LLM Endpoint (for custom/self-hosted models)
# Used by: prompt-eval TS steps (direct API calls)
# ──────────────────────────────────────────────
LLM_ENDPOINT=https://api.anthropic.com
